# ─────────────────────────────────────────────
# MACE - Inference Configuration
# ─────────────────────────────────────────────

# API Configuration
# Validator / proxy: set API_BASE_URL + API_KEY (API_KEY is preferred over HF_TOKEN).
# Local Hugging Face router: HF_TOKEN or OPENAI_API_KEY; omit API_KEY if unused.
API_BASE_URL=https://router.huggingface.co/v1
# API_KEY=your_proxy_key_here
HF_TOKEN=your_huggingface_token_here

# Model Configuration (choose ONE)
MODEL_NAME=meta-llama/Llama-3.3-70B-Instruct
# MODEL_NAME=meta-llama/Llama-3.2-3B-Instruct

# Inference Mode
# Options: scripted | llm | (omit = llm if API_BASE_URL+API_KEY set, else scripted)
AACE_INFERENCE_MODE=scripted

# Output Mode (optional; default is verbose if unset)
# Options: verbose | compact
# AACE_OUTPUT_MODE=compact

# Reproducibility
AACE_INFERENCE_SEED=42

# LLM Reliability Settings
AACE_LLM_MAX_RETRIES=3
AACE_LLM_RETRY_BACKOFF_MS=750
AACE_LLM_TIMEOUT_S=120